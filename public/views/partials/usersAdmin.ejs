<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('head') %>
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body>
    <div id="app-root">
      <%- include('navMin') %>

      <h2 class="usersFormTitle">Administración de usuarios</h2>

      <form id="usersForm">
        <div class="d-flex gap-2" style="padding: 0px 20px;">
          <input
            id="userSearch"
            class="form-control"
            placeholder="Buscar..."
            type="text"
          />

          <div class="form-check form-switch d-flex align-items-center">
            <input class="form-check-input" type="checkbox" id="toggleTipo" />
            <span class="roleSpinner d-none spinner-border spinner-border-sm"></span>
            <label for="toggleTipo" class="form-check-label ms-2">Transportistas</label>
          </div>

          <button id="addBtn" class="btn btn-primary d-none" type="button">
            + Nuevo
          </button>
        </div>

        <div class="usersAdminContainer">
          <table class="table table-hover usersAdminTable align-middle">
            <colgroup>
                <col id="col1" />
                <col id="col2" />
                <col />
            </colgroup>       
            <thead>
              <tr>
                <th id="thCol1">Email</th>
                <th id="thCol2" style="width: 220px">Rol</th>
                <th class="text-end">Acciones</th>
              </tr>
            </thead>

            <tbody>
              <% users.forEach(function(user){ %>

              <tr data-id="<%= user.id %>">
                <td class="usersEmail col1"><%= user.email %></td>

                <td col2>
                  <div style="display: flex; align-items: center; gap: 8px">
                    <select class="form-select form-select-sm roleSelect">
                      <% roles.forEach(function(role){ %>
                        <option value="<%= role.id %>" <%= role.name === user.role ? "selected" : "" %>>
                            <%= role.name %>
                        </option>
                      <% }) %>
                    </select>

                    <span
                      class="roleSpinner d-none spinner-border spinner-border-sm"
                    ></span>
                  </div>
                </td>

                <td class="text-end">
                  <button
                    class="btn btn-outline-danger btn-sm deleteUserBtn"
                    type="button"
                  >
                    Eliminar
                  </button>
                </td>
              </tr>

              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- <button class="sendBtn sendBtnUsersAdmin" type="submit">Enviar</button> -->
        <a class="formBackLink usersAdminBackBtn" href="/api/productos"
          ><button class="formBackLinkBtn">Volver</button></a
        >
      </form>

      <%- include('footer') %>
    </div>
    <script id="initialUsersData" type="application/json">
      <%- JSON.stringify(users) %>
    </script>
    <script src="../../js/usersAdmin.js"></script>
    <script
      type="text/javascript"
      src="https://cdn.jsdelivr.net/npm/toastify-js"
    ></script>
    <script src="../../js/toast.js"></script>
    <script src="../../js/pageAnimation.js"></script>
    <script src="/js/confirm-modal.js"></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
