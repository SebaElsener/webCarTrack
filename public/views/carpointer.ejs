<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
    <title>CarPointer - GPS tracking</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css"
    />
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  </head>

  <body>
    <div id="app-root">
      <%- include('./partials/navMin') %>
      <div class="navBarSeparator"></div>

      <main id="main">
        <div id="carpointerInputContainer" class="container mt-1">
          <div class="uploadBtnContainer">
            <input
              type="file"
              id="fileInput"
              accept=".xlsx,.xls"
              style="display: none"
            />

            <button id="uploadBtn" class="btn btn-outline-success">
              Actualizar movimientos
            </button>
            <div
              id="progressContainer"
              style="margin-top: 10px; width: 120px; display: none"
            >
              <div
                style="
                  background: #eee;
                  height: 20px;
                  border-radius: 8px;
                  overflow: hidden;
                "
              >
                <div
                  id="barra"
                  style="
                    height: 100%;
                    width: 0%;
                    background: #4caf50;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-size: 12px;
                    font-weight: bold;
                    transition: width 0.4s ease; /* 👈 CLAVE */
                  "
                ></div>
              </div>
              <div id="etapa"></div>
            </div>
          </div>
          <div>
            <div id="carpointer-title-date-input">
              <h3 class="carpointer-formTitle">Consulta por rango de fechas</h3>
              <form id="form-fechas">
                <div id="inputGroup" class="input-group">
                  <span class="input-group-text">📅</span>
                  <input
                    type="text"
                    id="rangoFechas"
                    class="form-control"
                    placeholder="Seleccionar fechas"
                    readonly
                  />
                  <div class="btnFormContainer">
                    <button
                      id="btnFormSubmit"
                      class="btn btn-primary"
                      type="submit"
                    >
                      Consultar
                    </button>
                  </div>
                </div>
              </form>
            </div>

            <div id="carpointer-title-VIN-input">
              <h3 class="carpointer-formTitle">Consulta chasis / VIN</h3>
              <form id="form-vin">
                <div id="VINinputGroup" class="input-group">
                  <input
                    type="text"
                    id="vinInput"
                    class="form-control"
                    placeholder="Ingrese chasis o VIN"
                    onInput="this.value = this.value.toUpperCase();"
                    maxlength="17"
                    autocomplete="off"
                  />
                  <div class="btnFormContainer">
                    <button
                      id="btnFormSubmit"
                      class="btn btn-primary"
                      type="submit"
                    >
                      Consultar
                    </button>
                  </div>
                  <div class="invalid-feedback" id="vinError"></div>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="card mb-3 shadow-sm post-table-action" id="filtersCard">
          <div class="card-body">
            <div
              class="row g-3 align-items-top"
              style="justify-content: center; gap: 2rem"
            >
              <!-- Marca -->
              <div class="col-md-2 filterContainer">
                <label class="form-label fw-semibold">Marca</label>
                <select id="filtroMarca" class="form-select" multiple>
                  <option value=""></option>
                </select>
              </div>
              <!-- Modelo -->
              <div class="col-md-2 filterContainer">
                <label class="form-label fw-semibold">Modelo</label>
                <select id="filtroModelo" class="form-select" multiple>
                  <option value=""></option>
                </select>
              </div>
              <!-- Batea -->
              <div class="col-md-2 filterContainer filterContainerBatea">
                <label class="form-label fw-semibold">Batea</label>
                <select id="filtroBatea" class="form-select" multiple>
                  <option value=""></option>
                </select>
              </div>
              <!-- Origen -->
              <div class="col-md-2 filterContainer filterContainerOrigen">
                <label class="form-label fw-semibold">Origen</label>
                <select id="filtroOrigen" class="form-select" multiple>
                  <option value=""></option>
                </select>
              </div>
              <!-- Destino -->
              <div class="col-md-2 filterContainer">
                <label class="form-label fw-semibold">Destino</label>
                <select id="filtroDestino" class="form-select" multiple>
                  <option value=""></option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div
          class="justify-content-between align-items-center post-table-action carpointer-actions-bar"
          id="actionsBar"
        >
          <button
            id="btnLimpiarFiltros"
            class="btn btn-sm btn-outline-secondary ms-2"
          >
            Limpiar filtros
          </button>
          <div class="btn-group" role="group" id="movimientoContainer">
            <div>
              <label
                class="form-check-label fw-semibold movimientoLabel"
                style="height: auto"
                >Filtrar movimientos</label
              >
            </div>
            <div id="movimientoFilterWrap">
              <input
                type="radio"
                class="btn-check"
                name="movimiento"
                id="movAll"
                checked
              />
              <label
                class="btn btn-outline-secondary movimientoLabel"
                for="movAll"
                >Todos</label
              >

              <input
                type="radio"
                class="btn-check"
                name="movimiento"
                id="movCarga"
              />
              <label
                class="btn btn-outline-success movimientoLabel"
                for="movCarga"
                >Carga</label
              >

              <input
                type="radio"
                class="btn-check"
                name="movimiento"
                id="movDescarga"
              />
              <label
                class="btn btn-outline-primary movimientoLabel"
                for="movDescarga"
                >Descarga</label
              >
            </div>
          </div>
          <div id="gpsTracing">
            <button id="btnVerMapa" class="btn btn-primary">
              🗺️ Ver recorrido
            </button>
          </div>
          <!-- Viaje -->
          <div class="col-md-2 filterContainer filterContainerCarpointer">
            <label class="form-label fw-semibold">Viaje:</label>
            <select id="filtroViaje" class="form-select" multiple>
              <option value=""></option>
            </select>
          </div>
        </div>

        <div id="tabla-wrapper" class="tabla-wrapper">
          <div id="tabla-scroll" class="tabla-scroll">
            <div id="resultados" class="container-fluid"></div>
          </div>
          <div id="paginacion" class="mt-3"></div>
        </div>
      </main>

      <div id="mapModal" class="map-modal">
        <div class="map-modal-content">
          <div class="map-header" id="mapHeader">
            <div class="timeLineWrapper">
              <div class="controlsContainer">
                <!-- <span>Posicionamiento carga / descarga</span> -->
                <button id="btnAnimarMapa">▶️ Recrear recorrido</button>
                <button onclick="setVelocidad(0.005)">🐢</button>
                <button onclick="setVelocidad(0.01)">▶️</button>
                <button onclick="setVelocidad(0.03)">⚡</button>
                <button id="btnPauseMapa">⏸️ Pause</button>
              </div>
              <div class="timelineContainer">
                <input
                  type="range"
                  id="timeline"
                  min="0"
                  max="100"
                  value="0"
                  style="width: 80%"
                />
              </div>
            </div>
            <button id="closeMapModal">✖</button>
          </div>
          <div id="map"></div>
        </div>
      </div>

      <%- include('./partials/footer') %>
    </div>

    <script type="module" src="/js/carpointer-gps.js"></script>
    <script type="module" src="/js/carpointer.js"></script>
    <script src="/js/pageAnimation.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    <script>
      const rangoPicker = flatpickr("#rangoFechas", {
        mode: "range",
        dateFormat: "Y-m-d", // valor real
        altInput: true,
        altFormat: "d/m/Y", // visible
        locale: flatpickr.l10ns.es,
        appendTo: document.body, // 🔥 clave
      });
    </script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
    <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
    <!-- Script toastify -->
    <script
      type="text/javascript"
      src="https://cdn.jsdelivr.net/npm/toastify-js"
    ></script>
    <script src="/js/toast.js"></script>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

    <script>
      const choicesMarca = new Choices("#filtroMarca", {
        removeItemButton: true,
        placeholder: true,
        //placeholderValue: "Buscar marca...",
        //searchPlaceholderValue: "Buscar...",
        itemSelectText: "",
        shouldSort: true,
        searchEnabled: true,
      });

      const choicesModelo = new Choices("#filtroModelo", {
        removeItemButton: true,
        placeholder: true,
        // placeholderValue: "Buscar modelo...",
        // searchPlaceholderValue: "Buscar...",
        itemSelectText: "",
        shouldSort: true,
        searchEnabled: true,
      });

      const choicesBatea = new Choices("#filtroBatea", {
        removeItemButton: true,
        placeholder: true,
        //placeholderValue: "Buscar batea...",
        //searchPlaceholderValue: "Buscar...",
        itemSelectText: "",
        shouldSort: true,
        searchEnabled: true,
      });

      const choicesOrigenes = new Choices("#filtroOrigen", {
        removeItemButton: true,
        searchEnabled: true,
        //placeholderValue: "Lugar",
        itemSelectText: "",
        shouldSort: false,
      });

      const choicesDestino = new Choices("#filtroDestino", {
        removeItemButton: true,
        searchEnabled: true,
        //placeholderValue: "Destino",
        itemSelectText: "",
        shouldSort: false,
      });

      const choicesViaje = new Choices("#filtroViaje", {
        removeItemButton: true,
        placeholder: true,
        //placeholderValue: "Viajes:  todos",
        searchPlaceholderValue: "Buscar...",
        itemSelectText: "",
        shouldSort: true,
        searchEnabled: true,
      });
    </script>

    <script>
      document.addEventListener("glightbox_open", () => {
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
      });

      document.addEventListener("glightbox_close", () => {
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
      });
    </script>
  </body>
</html>
