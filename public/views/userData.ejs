<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>

    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
  </head>

  <body>
    <div id="app-root">
      <%- include('./partials/navMin') %>

      <h2 class="usersFormTitle">Mis datos</h2>

      <form id="userDataForm" autocomplete="off">
        <label class="userName" for="userName"
          ><span class="labelTitle">Mi email</span>
          <input
            id="userName"
            class="userNameInput"
            name="username"
            type="email"
            value="<%= userName %>"
            disabled
          />
          <input id="_id" type="hidden" value="<%= userData.id %>" name="_id" />
        </label>
        <label class="userName" for="nameLastname"
          ><span class="labelTitle">Mi nombre y apellido</span>
          <input
            id="nameLastname"
            class="userNameInput"
            name="nameLastname"
            type="text"
            value="<%= userData.name %>"
          />
        </label>
        <label class="userName" for="direccion"
          ><span class="labelTitle">Mi dirección</span>
          <input
            id="direccion"
            class="userNameInput"
            name="address"
            type="text"
            value="<%= userData.address %>"
          />
        </label>
        <label class="userName" for="phone"
          ><span class="labelTitle">Mi teléfono</span>
          <input
            id="phone"
            class="userNameInput"
            name="phone"
            type="text"
            value="<%= userData.phone %>"
          />
        </label>

        <button class="regBtn" type="submit">Guardar</button>
      </form>

      <div class="userDataBtnContainer">
        <button id="passChangeBtn" class="regBtn">Cambiar mi contraseña</button>
        <a class="formBackLink" href="/api/productos"
          ><button class="formBackLinkBtn">Volver</button></a
        >
      </div>

      <form id="passForm" autocomplete="off">
        <div id="passContainer">
          <label class="userName" for="userPass"
            ><span class="labelTitle">Contraseña actual</span>
            <input
              id="actualUserPass"
              class="userPassInput"
              name="password"
              type="password"
              required
            />
          </label>
          <label class="userName" for="userPass"
            ><span class="labelTitle">Nueva contraseña</span>
            <input
              id="userPass"
              class="userPassInput"
              name="newPassword"
              type="password"
              required
            />
          </label>
          <label class="userName" for="userPass"
            ><span class="labelTitle">Reingrese contraseña</span>
            <input
              id="userPassCheck"
              class="userPassInput"
              name="checkPassword"
              type="password"
              required
            />
          </label>
          <p id="errorPassCheck">LA CONTRASEÑA Y EL REINGRESO NO COINCIDEN</p>
          <p id="errorValidPass">
            LA CONTRASEÑA DEBE TENER AL MENOS 8 CARACTERES, MAYUSCULAS,
            MINUSCULAS Y NUMEROS
          </p>
        </div>
        <button id="sendBtn" class="regBtn" type="submit" disabled>
          Cambiar
        </button>
      </form>

      <%- include('./partials/footer') %>
    </div>
    <script src="/js/userData.js"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/passwordCheck.js"></script>
    <script src="/js/pageAnimation.js"></script>
    <!-- <script src=" https://cdn.jsdelivr.net/npm/bcryptjs@2.4.3/dist/bcrypt.min.js "></script> -->
    <script
      type="text/javascript"
      src="https://cdn.jsdelivr.net/npm/toastify-js"
    ></script>
    <script></script>
  </body>
</html>
