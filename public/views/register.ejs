<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro usuario</title>
    <link rel="stylesheet" href="../css/index.css" />
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />
  </head>

  <body>
    <div id="app-root">
      <main>
        <form id="regForm" autocomplete="off">
          <h2 class="regFormTitle">Registro de usuario</h2>
          <label class="userName" for="userName"
            ><span class="labelTitle">Ingrese su email</span>
            <div class="field">
              <input
                id="userName"
                class="userNameInput"
                name="username"
                type="email"
                required
                autocomplete="off"
              />
              <div class="inline-error" id="emailError">
                Ingrese un email válido
              </div>
            </div>
          </label>
          <label class="userName" for="userPass"
            ><span class="labelTitle">Ingrese una contraseña</span>
            <input
              id="userPass"
              class="userPassInput"
              name="password"
              type="password"
              required
            />
          </label>
          <label class="userName" for="userPassCheck"
            ><span class="labelTitle">Reingrese la contraseña</span>
            <input
              id="userPassCheck"
              class="userPassCheckInput"
              name="passwordCheck"
              type="password"
              required
            />
          </label>
          <p id="errorPassCheck">LA CONTRASEÑA Y EL REINGRESO NO COINCIDEN</p>
          <p id="errorValidPass">
            LA CONTRASEÑA DEBE TENER AL MENOS 8 CARACTERES, MAYUSCULAS,
            MINUSCULAS Y NUMEROS
          </p>
          <label class="userName" for="nameLastname"
            ><span class="labelTitle">Nombre y apellido</span>
            <input
              id="nameLastname"
              class="userNameInput"
              name="nameLastname"
              type="text"
              required
            />
          </label>
          <label class="userName" for="direccion"
            ><span class="labelTitle">Dirección</span>
            <input
              id="direccion"
              class="userNameInput"
              name="address"
              type="text"
            />
          </label>
          <label class="userName" for="phone"
            ><span class="labelTitle">Teléfono</span>
            <input id="phone" class="userNameInput" name="phone" type="text" />
          </label>
          <button id="sendBtn" class="regBtn" type="submit" disabled>
            Enviar
          </button>
        </form>
        <div class="gotoLoginContainer">
          <p class="loginContainerText">¿Ya estás registrado? Ir a</p>
          <a class="loginLink" href="/api/login">
            <button class="regBtn">Login</button>
          </a>
        </div>
      </main>
    </div>
    <script src="/js/passwordCheck.js"></script>
    <script src="/js/register.js"></script>
    <script src="/js/pageAnimation.js"></script>
    <script
      type="text/javascript"
      src="https://cdn.jsdelivr.net/npm/toastify-js"
    ></script>
    <script src="/js/toast.js"></script>
  </body>
</html>
